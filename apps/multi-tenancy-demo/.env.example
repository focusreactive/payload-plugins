# SQLite database file for the demo. A relative file: URL keeps it inside the app dir.
DATABASE_URL=file:./multi-tenancy-demo.db
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public URL used by the frontend preview routes.
NEXT_PUBLIC_SERVER_URL=http://localhost:4041

# Optional: override the seeded admin credentials (defaults below match the seed).
SEED_ADMIN_EMAIL=admin@admin.com
SEED_ADMIN_PASSWORD=admin
