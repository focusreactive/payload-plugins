{
  "name": "dev",
  "version": "1.0.0",
  "private": true,
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --port 4040",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "format": "ultracite fix",
    "format:check": "ultracite check",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "bun run src/seed.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@focus-reactive/payload-plugin-ab": "workspace:*",
    "@focus-reactive/payload-plugin-analytics": "workspace:*",
    "@focus-reactive/payload-plugin-comments": "workspace:*",
    "@focus-reactive/payload-plugin-presets": "workspace:*",
    "@focus-reactive/payload-plugin-scheduling": "workspace:*",
    "@focus-reactive/payload-plugin-seo": "workspace:*",
    "@focus-reactive/payload-plugin-translator": "workspace:*",
    "@google-analytics/data": "^5.2.2",
    "@grpc/grpc-js": "^1.14.3",
    "@payloadcms/db-sqlite": "3.79.0",
    "@payloadcms/live-preview-react": "3.79.0",
    "@payloadcms/next": "3.79.0",
    "@payloadcms/richtext-lexical": "3.79.0",
    "@payloadcms/ui": "3.79.0",
    "cross-env": "7.0.3",
    "dotenv": "16.4.7",
    "google-auth-library": "^10.6.2",
    "google-gax": "^5.0.6",
    "graphql": "16.8.1",
    "next": "16.2.6",
    "payload": "3.79.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@types/node": "22.19.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "jsdom": "26.1.0",
    "typescript": "5.9.2",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
