{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "noUncheckedIndexedAccess": false,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/dal": ["./src/lib/dal"],
      "@/dal/*": ["./src/lib/dal/*"],
      "@/*": ["./src/*"],
      "@payload-config": ["./src/payload.config.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
