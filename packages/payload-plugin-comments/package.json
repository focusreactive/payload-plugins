    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "@payloadcms/plugin-multi-tenant": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "next": "^14.0.0 || ^15.0.0",
    "payload": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@payloadcms/plugin-multi-tenant": {
      "optional": true
