    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "next": "15.4.10",
    "payload": "3.79.0",
    "@payloadcms/ui": "3.79.0",
    "@payloadcms/plugin-multi-tenant": "3.79.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.0.0",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.0.0"
  }
