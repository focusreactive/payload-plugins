      "import": "./dist/client/blocks/index.js",
      "types": "./dist/client/blocks/index.d.ts"
    },
    "./admin.css": "./dist/admin.css",
    "./components/AnalyticsView": {
      "import": "./dist/components/AnalyticsView/index.js",
      "types": "./dist/components/AnalyticsView/index.d.ts"
    },
    "./components/AnalyticsView/AnalyticsHeaderLink": {
      "import": "./dist/components/AnalyticsView/AnalyticsHeaderLink.js",
      "types": "./dist/components/AnalyticsView/AnalyticsHeaderLink.d.ts"
    }
  },
  "scripts": {
    "build": "node node_modules/tsup/dist/cli-default.js && tsc --emitDeclarationOnly --declarationMap",
    "dev": "node node_modules/tsup/dist/cli-default.js --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
