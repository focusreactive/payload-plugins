    "payload": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-day-picker": "^9.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "recharts": "^2.15.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.2",
